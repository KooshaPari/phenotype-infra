# EditorConfig — Phenotype org canonical
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{rs,toml,py,go,md,yaml,yml,json,html,css,scss}]
indent_size = 4

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false  # trailing spaces = line break in Markdown

# --- appended by L2 #28 on 2026-06-11 ---
[*.rs]
indent_size = 4
max_line_length = 100

[*.go]
indent_style = tab
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.{toml,yaml,yml,json,html,css,scss}]
indent_size = 2

[*.{zsh,sh,bash}]
indent_size = 2

[*.{diff,patch}]
trim_trailing_whitespace = false
