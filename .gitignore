# phenotype-infra .gitignore
# NOTE: Do NOT add blanket `Cargo.toml` ignores — per audit #105, this silently
# hides per-crate manifests. List specific build output dirs only.

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# --- Editors ---
.idea/
.vscode/
*.swp
*.swo
*~
.netrwhist

# --- Rust ---
/target/
**/target/
*.rs.bk
Cargo.lock.bak
# explicit: keep root and per-crate Cargo.toml tracked

# --- Terraform ---
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# --- Ansible ---
*.retry
inventory.yml
!inventory.yml.example
vault_pass.txt
.vault_pass

# --- Python (for any generator scripts) ---
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.ruff_cache/
.pytest_cache/
.venv/
venv/

# --- Node (for docsite, if added later) ---
node_modules/
.pnp
.pnp.*
.pnp.js
.yarn/
.npm/
.cache/
.eslintcache
.parcel-cache/
dist/
.next/
build/
/out/
lerna-debug.log*
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Secrets / creds (defense in depth) ---
*.pem
*.key
*.p12
*.pfx
*_rsa
id_rsa*
id_ed25519*
*credential*.json
*credentials*.json
*service-account*.json
.env
.env.*
!.env.example
.npmrc
.pypirc
.netrc
credentials
credentials.json
secrets.yml
!secrets.yml.example

# --- Logs ---
*.log
logs/

# --- OS / misc ---
Thumbs.db
ehthumbs.db

# --- Test / coverage ---
coverage/
/coverage/

# --- Grade artifacts ---
.grade-reports/
grade.sh
lefthook.yml

# --- Incident evidence (local-only) ---
incident-evidence/
.incident-evidence/
local/incident-evidence/

# --- Root-level Rust lockfile (regenerated on first build) ---
# Per workspace convention: do not track top-level Cargo.lock.
# Per-crate Cargo.lock files (under workspace members) are unaffected.
Cargo.lock
