# T22 Observability endpoint (pheno-tracing substrate, ADR-036).
#
# The current pheno-tracing substrate (v0.1) ships a port-driven TracePort
# with local adapters (StdoutAdapter, InMemoryAdapter). Set
# OTEL_EXPORTER_OTLP_ENDPOINT to the planned OTLP collector location so
# that downstream tooling (pheno-otel adapter, ADR-036 future) picks it
# up automatically once the OtlpAdapter lands.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=phenotype-infra

# RUST_LOG controls the EnvFilter. Default is "info"; set "debug" or
# "trace" for verbose spans. Per-crate filter is supported.
RUST_LOG=info,oci_lottery=debug,oci_post_acquire=debug
