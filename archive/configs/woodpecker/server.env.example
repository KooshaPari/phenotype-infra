# Woodpecker server env — EXAMPLE.

WOODPECKER_HOST=https://ci.phenotype.io
WOODPECKER_OPEN=false
WOODPECKER_ADMIN=koosha

# Forgejo OAuth (create in Forgejo → Site Admin → Applications → OAuth2)
WOODPECKER_GITEA=true
WOODPECKER_GITEA_URL=https://git.phenotype.io
WOODPECKER_GITEA_CLIENT=<FORGEJO_OAUTH_CLIENT_ID>
WOODPECKER_GITEA_SECRET=<FORGEJO_OAUTH_CLIENT_SECRET>

WOODPECKER_AGENT_SECRET=<WP-AGENT-SHARED-SECRET>

WOODPECKER_SERVER_ADDR=:8000
WOODPECKER_GRPC_ADDR=:9000

WOODPECKER_DATABASE_DRIVER=sqlite3
WOODPECKER_DATABASE_DATASOURCE=/var/lib/woodpecker/woodpecker.sqlite

WOODPECKER_LOG_LEVEL=info
